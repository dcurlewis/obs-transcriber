# ===================================================================
# OBS Meeting Transcriber Configuration
# ===================================================================
#
# Copy this file to .env and customize for your setup:
#   cp .env.example .env
#
# Environment variables override .env file values (useful for CI/production)
#

# ===================================================================
# === OBS Configuration ===
# ===================================================================
# Settings for OBS WebSocket connection
# Find these in OBS: Tools -> WebSocket Server Settings

# REQUIRED
# Password for OBS WebSocket
# This must match the password configured in OBS WebSocket Server Settings
OBS_PASSWORD=your_obs_websocket_password

# OPTIONAL
# OBS host address (default: localhost)
# Change this only if OBS is running on a different machine
OBS_HOST=localhost

# OPTIONAL
# OBS WebSocket port (default: 4455)
# This is the default OBS WebSocket port (v5.0+)
OBS_PORT=4455

# ===================================================================
# === Whisper Transcription Settings ===
# ===================================================================
# MLX Whisper configuration (Apple Silicon optimized)
# Whisper models are downloaded automatically on first use

# OPTIONAL
# Whisper model to use (default: turbo)
# Options: tiny, base, small, medium, large-v3, turbo, distil-large-v3
# Recommended: turbo (best speed/accuracy balance)
# Notes:
#   - tiny/base: Fast but less accurate
#   - turbo: Best balance for most use cases
#   - large-v3: Most accurate but slower and more memory-intensive
WHISPER_MODEL=turbo

# OPTIONAL
# Language code for transcription (default: en)
# Use ISO 639-1 codes (e.g., 'en' for English, 'es' for Spanish, 'fr' for French)
WHISPER_LANGUAGE=en

# ===================================================================
# === Path Configuration ===
# ===================================================================

# REQUIRED
# Path to OBS recordings directory
# This MUST match "Recording Path" in OBS settings:
#   OBS -> Settings -> Output -> Recording -> Recording Path
# Supports ~ for home directory (e.g., ~/Movies or ~/Meetings)
# The script will monitor this directory for new recordings
RECORDING_PATH=~/Movies

# REQUIRED
# Directory for transcription output
# Final transcript files will be saved here as YYYYMMDD-Meeting-Name_transcript.txt
# This directory will be created automatically if it doesn't exist
# Supports ~ for home directory (e.g., ~/Documents/Transcripts)
TRANSCRIPTION_OUTPUT_DIR=~/Documents/Transcripts

# ===================================================================
# === Calendar Integration ===
# ===================================================================

# REQUIRED
# Your email address for filtering calendar events
# Used to identify which calendar events you're attending
# The script matches this email against calendar event attendees
# to determine the meeting name for recordings
USER_EMAIL=your.email@example.com

# OPTIONAL
# Filter which calendars to include in the web UI
# Comma-separated list of calendar names (case-insensitive partial matching)
# If set, ONLY meetings from these calendars will be shown
# Example: CALENDAR_INCLUDE=your.email@example.com,Personal Calendar
# Leave blank to show meetings from all calendars
# CALENDAR_INCLUDE=

# OPTIONAL
# Exclude specific calendars from the web UI
# Comma-separated list of calendar names (case-insensitive partial matching)
# If set, meetings from these calendars will be hidden
# Example: CALENDAR_EXCLUDE=Team Calendar,Shared Events
# Leave blank to show meetings from all calendars
# Note: CALENDAR_INCLUDE takes precedence if both are set
# CALENDAR_EXCLUDE=

# ===================================================================
# === Optional Settings ===
# ===================================================================

# OPTIONAL
# Keep raw recordings after processing (default: false)
# Set to 'true' to preserve original MKV files after transcription
# Useful for troubleshooting or if you want to reprocess recordings later
# Note: MKV files are large; keeping them will use significant disk space
KEEP_RAW_RECORDING=false

# ===================================================================
# === Speaker Diarization ===
# ===================================================================
# Identifies individual speakers in the "Others" audio track and labels
# each segment with [Speaker 1], [Speaker 2], etc. in the transcript.

# OPTIONAL
# Enable speaker diarization on the 'others' track (default: false)
# Requires HF_TOKEN to be set (see below).
# One-time setup:
#   1. Create a HuggingFace account at https://huggingface.co
#   2. Accept the model license: https://huggingface.co/pyannote/speaker-diarization-3.1
#   3. Accept the model license: https://huggingface.co/pyannote/segmentation-3.0
#   4. Generate a read token: https://huggingface.co/settings/tokens
#   5. Paste the token as HF_TOKEN below and set ENABLE_DIARIZATION=true
# ENABLE_DIARIZATION=false

# OPTIONAL
# HuggingFace access token for pyannote model download.
# Required when ENABLE_DIARIZATION=true.
# Models are downloaded once and cached in ~/.cache/huggingface/
# HF_TOKEN=hf_your_token_here
